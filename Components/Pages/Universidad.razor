@page "/universidad"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<PageTitle>Universidades</PageTitle>

<div class="container mt-4">
    <h3>Universidades</h3>

    @* ───────── ALERTA ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* ───────── BOTON NUEVO ───────── *@
    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Universidad</button>
    }

    @* ───────── LIMITE DE REGISTROS ───────── *@
    <div class="d-flex align-items-center mb-3">
        <label class="form-label me-2 mb-0">Límite:</label>
        <input class="form-control me-2" type="number" style="width:100px" @bind="limite" />
        <button class="btn btn-outline-secondary" @onclick="CargarRegistros">Cargar</button>
    </div>

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar Universidad" : "Nueva Universidad")
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">ID (Código)</label>
                        <input class="form-control" type="number" @bind="campoId" disabled="@editando" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" @bind="campoNombre" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Tipo (Pública/Privada)</label>
                        <input class="form-control" @bind="campoTipo" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Ciudad</label>
                        <input class="form-control" @bind="campoCiudad" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @* ───────── SPINNER ───────── *@
    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @* ───────── TABLA ───────── *@
    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Tipo</th>
                    <th>Ciudad</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["id"]</td>
                        <td>@reg["nombre"]</td>
                        <td>@reg["tipo"]</td>
                        <td>@reg["ciudad"]</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1"
                                    @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en la tabla universidad.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    // Campos del formulario (coinciden con tu tabla SQL)
    private string campoId = string.Empty;
    private string campoNombre = string.Empty;
    private string campoTipo = string.Empty;
    private string campoCiudad = string.Empty;
    private int? limite = null;

    protected override async Task OnInitializedAsync()
    {
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("universidad", limite);
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false;
        campoId = string.Empty;
        campoNombre = string.Empty;
        campoTipo = string.Empty;
        campoCiudad = string.Empty;
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = reg["id"]?.ToString() ?? "";
        campoNombre = reg["nombre"]?.ToString() ?? "";
        campoTipo = reg["tipo"]?.ToString() ?? "";
        campoCiudad = reg["ciudad"]?.ToString() ?? "";
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        // Los nombres de las llaves deben ser exactos a las columnas de tu BD
        var datos = new Dictionary<string, object?>
        {
            ["id"] = campoId,
            ["nombre"] = campoNombre,
            ["tipo"] = campoTipo,
            ["ciudad"] = campoCiudad
        };

        if (editando)
        {
            datos.Remove("id"); // No actualizamos la Primary Key
            // Nota que aquí le pasamos "id" como nombre de la clave
            var resultado = await Api.ActualizarAsync("universidad", "id", campoId, datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("universidad", datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string id = reg["id"]?.ToString() ?? "";
        // Nuevamente, aseguramos que la clave que enviamos es "id"
        var resultado = await Api.EliminarAsync("universidad", "id", id);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
            await CargarRegistros();
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }
}