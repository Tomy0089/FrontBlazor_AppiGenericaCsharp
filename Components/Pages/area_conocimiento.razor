@page "/area-conocimiento"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<PageTitle>Áreas del Conocimiento</PageTitle>

<div class="container mt-4">
    <h3>Gestión de Áreas del Conocimiento</h3>

    @* ───────── ALERTAS ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* ───────── BOTÓN NUEVO ───────── *@
    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Área</button>
    }

    @* ───────── FILTRO LÍMITE ───────── *@
    <div class="d-flex align-items-center mb-3">
        <label class="form-label me-2 mb-0">Límite:</label>
        <input class="form-control me-2" type="number" style="width:100px" @bind="limite" />
        <button class="btn btn-outline-secondary" @onclick="CargarRegistros">Cargar</button>
    </div>

    @* ───────── FORMULARIO (Tabla 7: area_conocimiento) ───────── *@
    @if (mostrarFormulario)
    {
        <div class="card mb-3 shadow-sm">
            <div class="card-header bg-dark text-white">
                @(editando ? "Editar Área del Conocimiento" : "Registrar Nueva Área")
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label class="form-label">ID</label>
                        <input class="form-control" type="number" @bind="campoId" disabled="@editando" />
                    </div>
                    <div class="col-md-9 mb-3">
                        <label class="form-label">Gran Área</label>
                        <input class="form-control" @bind="campoGranArea" placeholder="Ej: Ingeniería, Ciencias de la Salud..." />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Área</label>
                        <input class="form-control" @bind="campoArea" placeholder="Ej: Ingeniería de Sistemas" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Disciplina</label>
                        <input class="form-control" @bind="campoDisciplina" placeholder="Ej: Inteligencia Artificial" />
                    </div>
                </div>
                <div class="mt-2">
                    <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                    <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                </div>
            </div>
        </div>
    }

    @* ───────── SPINNER ───────── *@
    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @* ───────── TABLA (area_conocimiento) ───────── *@
    @if (!cargando && registros.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover border">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Gran Área</th>
                        <th>Área</th>
                        <th>Disciplina</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reg in registros)
                    {
                        <tr>
                            <td>@reg["id"]</td>
                            <td>@reg["gran_area"]</td>
                            <td>@reg["area"]</td>
                            <td>@reg["disciplina"]</td>
                            <td>
                                <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                                <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No hay registros en el área de conocimiento.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    // Campos vinculados a Tabla 7: area_conocimiento
    private string campoId = string.Empty;
    private string campoGranArea = string.Empty;
    private string campoArea = string.Empty;
    private string campoDisciplina = string.Empty;
    private int? limite = null;

    protected override async Task OnInitializedAsync()
    {
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        // Nombre de la tabla exacto: area_conocimiento
        registros = await Api.ListarAsync("area_conocimiento", limite);
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false;
        campoId = string.Empty;
        campoGranArea = string.Empty;
        campoArea = string.Empty;
        campoDisciplina = string.Empty;
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = reg["id"]?.ToString() ?? "";
        campoGranArea = reg["gran_area"]?.ToString() ?? "";
        campoArea = reg["area"]?.ToString() ?? "";
        campoDisciplina = reg["disciplina"]?.ToString() ?? "";
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["id"] = int.Parse(campoId),
            ["gran_area"] = campoGranArea,
            ["area"] = campoArea,
            ["disciplina"] = campoDisciplina
        };

        if (editando)
        {
            datos.Remove("id");
            var resultado = await Api.ActualizarAsync("area_conocimiento", "id", campoId, datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("area_conocimiento", datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string id = reg["id"]?.ToString() ?? "";
        var resultado = await Api.EliminarAsync("area_conocimiento", "id", id);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito) await CargarRegistros();
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }
}