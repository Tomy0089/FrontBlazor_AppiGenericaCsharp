@page "/enfoque"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<PageTitle>Enfoques</PageTitle>

<div class="container mt-4">
    <h3>Gestión de Enfoques</h3>

    @* ───────── ALERTAS ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* ───────── BOTÓN NUEVO ───────── *@
    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Enfoque</button>
    }

    @* ───────── FILTRO LÍMITE ───────── *@
    <div class="d-flex align-items-center mb-3">
        <label class="form-label me-2 mb-0">Mostrar:</label>
        <input class="form-control me-2" type="number" style="width:100px" @bind="limite" />
        <button class="btn btn-outline-secondary" @onclick="CargarRegistros">Refrescar</button>
    </div>

    @* ───────── FORMULARIO (Basado en Tabla 3) ───────── *@
    @if (mostrarFormulario)
    {
        <div class="card mb-3 shadow-sm">
            <div class="card-header bg-dark text-white">
                @(editando ? "Editar Enfoque" : "Nuevo Enfoque")
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">ID (Código)</label>
                        <input class="form-control" type="number" @bind="campoId" disabled="@editando" />
                    </div>
                    <div class="col-md-8 mb-3">
                        <label class="form-label">Nombre del Enfoque</label>
                        <input class="form-control" @bind="campoNombre" placeholder="Ej: Investigación Básica" />
                    </div>
                    <div class="col-md-12 mb-3">
                        <label class="form-label">Descripción</label>
                        <textarea class="form-control" @bind="campoDescripcion" rows="2"></textarea>
                    </div>
                </div>
                <div class="mt-2">
                    <button class="btn btn-success me-2" @onclick="GuardarRegistro">
                        <i class="bi bi-save"></i> Guardar
                    </button>
                    <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                </div>
            </div>
        </div>
    }

    @* ───────── INDICADOR DE CARGA ───────── *@
    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @* ───────── TABLA DE DATOS ───────── *@
    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover border">
            <thead class="table-dark">
                <tr>
                    <th style="width: 10%">ID</th>
                    <th style="width: 30%">Nombre</th>
                    <th style="width: 40%">Descripción</th>
                    <th style="width: 20%">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td><strong>@reg["id"]</strong></td>
                        <td>@reg["nombre"]</td>
                        <td>@reg["descripcion"]</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">
                                Editar
                            </button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">
                                Eliminar
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-info">No hay enfoques registrados actualmente.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    // Campos vinculados a la Tabla 3: enfoque
    private string campoId = string.Empty;
    private string campoNombre = string.Empty;
    private string campoDescripcion = string.Empty;
    private int? limite = null;

    protected override async Task OnInitializedAsync()
    {
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        // Apuntamos a la tabla "enfoque"
        registros = await Api.ListarAsync("enfoque", limite);
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false;
        campoId = string.Empty;
        campoNombre = string.Empty;
        campoDescripcion = string.Empty;
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = reg["id"]?.ToString() ?? "";
        campoNombre = reg["nombre"]?.ToString() ?? "";
        campoDescripcion = reg["descripcion"]?.ToString() ?? "";
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["id"] = int.Parse(campoId),
            ["nombre"] = campoNombre,
            ["descripcion"] = campoDescripcion
        };

        if (editando)
        {
            datos.Remove("id"); 
            var resultado = await Api.ActualizarAsync("enfoque", "id", campoId, datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("enfoque", datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string id = reg["id"]?.ToString() ?? "";
        var resultado = await Api.EliminarAsync("enfoque", "id", id);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito) await CargarRegistros();
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }
}